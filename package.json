{
  "name": "yourmillionare",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.10.0"
  },
  "workspaces": [
    "infrastructure",
    "apps/*"
  ],
  "scripts": {
    "synth": "npm run synth --workspace=@ym/infrastructure",
    "test": "npm run test --workspaces --if-present",
    "lint": "eslint --no-error-on-unmatched-pattern \"infrastructure/**/*.ts\" \"apps/**/*.ts\"",
    "format": "prettier --write \"infrastructure/**/*.{ts,json}\" \"apps/**/*.{ts,json}\""
  },
  "devDependencies": {
    "@eslint/js": "^9.10.0",
    "@types/node": "^20.14.10",
    "eslint": "^9.10.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.6.0",
    "vitest": "^2.1.1"
  }
}
